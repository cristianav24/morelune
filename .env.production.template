# ─── Producción VPS ──────────────────────────────────────────
# Copiar a .env y rellenar con tus valores reales

# PostgreSQL
POSTGRES_PASSWORD=cambia_esto_por_contraseña_segura

# URLs (reemplaza tudominio.com por tu dominio real)
SITE_URL=https://tudominio.com
MEDUSA_BACKEND_URL=https://api.tudominio.com

# CORS
STORE_CORS=https://tudominio.com
ADMIN_CORS=https://api.tudominio.com
AUTH_CORS=https://tudominio.com,https://api.tudominio.com

# Seguridad (generar con: openssl rand -base64 64)
JWT_SECRET=GENERAR_CON_OPENSSL
COOKIE_SECRET=GENERAR_CON_OPENSSL

# Culqi
CULQI_PUBLIC_KEY=pk_live_xxxx
CULQI_SECRET_KEY=sk_live_xxxx
CULQI_WEBHOOK_SECRET=wh_xxxx

# Medusa publishable key (obtener del admin panel después del primer deploy)
MEDUSA_PUBLISHABLE_KEY=pk_xxxx

# Google Analytics (opcional)
GA_ID=G-XXXXXXXXXX

# Email (opcional pero recomendado para notificaciones de pedidos)
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@tudominio.com
